{
  "lora": {
    "r": 8,
    "lora_alpha": 16,
    "target_modules": ["q_proj","k_proj","v_proj","o_proj","gate_proj","up_proj","down_proj"],
    "lora_dropout": 0.05,
    "bias": "none",
    "task_type": "CAUSAL_LM"
  },
  "training": {
    "per_device_train_batch_size": 4,
    "gradient_accumulation_steps": 4,
    "learning_rate": 1e-4,
    "num_train_epochs": 3,
    "warmup_ratio": 0.05,
    "fp16": true
  },
  "output": {"output_dir": "./output/sen3b-finetuned"}
}
